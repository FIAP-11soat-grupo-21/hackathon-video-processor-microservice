# Configurações da API do Video Processor
# Para ambiente de desenvolvimento local

# API
API_URL=localhost:8080
GO_ENV=development
LOG_LEVEL=DEBUG

# AWS (para desenvolvimento com LocalStack)
AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# SQS
FRAME_QUEUE_URL=http://localhost:4566/000000000000/video-frame-queue

# S3
S3_BUCKET=fiap-tc-terraform-846874

# FFmpeg
FFMPEG_PATH=/usr/bin/ffmpeg

# Processamento
FRAME_QUALITY=85
FRAME_FORMAT=jpg
MAX_CONCURRENT_JOBS=5
PROCESS_TIMEOUT_SEC=300

# Para produção, use:
# GO_ENV=production
# LOG_LEVEL=INFO
# Configure credenciais AWS reais
# Use URLs reais do SQS e S3